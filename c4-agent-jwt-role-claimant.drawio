    <mxCell id="fr" value="&lt;b&gt;ICB TMS ForgeRock&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#1a3a6e&quot;&gt;[Container | ForgeRock AM 7.x]&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#1a3a6e&quot;&gt;① Receives token exchange request from Salesforce.&lt;br&gt;② Validates Salesforce self-signed JWT signature.&lt;br&gt;③ Extracts &lt;b&gt;chase.role&lt;/b&gt; claim.&lt;br&gt;④ Issues colleague token with &lt;b&gt;CRM_ROLE&lt;/b&gt; embedded.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#003087;fontColor=#003087;fontSize=11;verticalAlign=top;arcSize=4;spacingTop=5;" vertex="1" parent="1">
      <mxGeometry x="445" y="305" width="275" height="175" as="geometry"/>
    </mxCell>
    <mxCell id="cm" value="&lt;b&gt;ICB Case Manager&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#1a3a6e&quot;&gt;[Container | Spring Boot REST API]&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#1a3a6e&quot;&gt;① Validates Bearer token (OBO or Colleague).&lt;br&gt;② Extracts &lt;b&gt;CRM_ROLE&lt;/b&gt; from access token.&lt;br&gt;③ Forwards role to Florence via header:&lt;br&gt;&lt;b&gt;Jpmorgan-Authorization-Attribute:&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;jpmc.crm.role=CRM_ROLE&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#003087;fontColor=#003087;fontSize=11;verticalAlign=top;arcSize=4;spacingTop=5;" vertex="1" parent="1">
      <mxGeometry x="775" y="545" width="280" height="185" as="geometry"/>
    </mxCell>
    <mxCell id="cache" value="&lt;b&gt;Token Cache&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#7a4800&quot;&gt;[Container | Redis / In-Memory]&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#7a4800&quot;&gt;Caches access tokens (TTL = token expiry) to avoid redundant ForgeRock calls.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9e6;strokeColor=#d6b656;fontColor=#7a4800;fontSize=10;verticalAlign=top;arcSize=4;spacingTop=4;" vertex="1" parent="1">
