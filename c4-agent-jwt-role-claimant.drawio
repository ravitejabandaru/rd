    <mxCell id="sf" value="&lt;b&gt;Salesforce CRM&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#555&quot;&gt;[External System | Salesforce Lightning]&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#444&quot;&gt;Agent UI. Performs SAML SSO via IDAnywhere.&lt;br&gt;Generates self-signed internal JWT with&lt;br&gt;&lt;b&gt;chase.role = CRM_ROLE&lt;/b&gt;.&lt;br&gt;Calls Case Manager with OBO token&lt;br&gt;(customer) or Colleague token (non-customer).&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontColor=#333333;fontSize=11;verticalAlign=top;arcSize=4;spacingTop=5;" vertex="1" parent="1">
      <mxGeometry x="30" y="335" width="205" height="185" as="geometry"/>
    </mxCell>
    <mxCell id="ida" value="&lt;b&gt;IDAnywhere SAML IdP&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#555&quot;&gt;[External System | SAML 2.0 IdP]&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#444&quot;&gt;Federated identity provider.&lt;br&gt;⚠ Roles tied to Salesforce SEAL ID.&lt;br&gt;Cannot be used in ForgeRock context&lt;br&gt;— root cause of the constraint.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontColor=#333333;fontSize=11;verticalAlign=top;arcSize=4;spacingTop=5;" vertex="1" parent="1">
