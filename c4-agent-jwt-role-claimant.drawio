    <mxCell id="agent" value="&lt;b&gt;Salesforce Agent&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#1a3a6e&quot;&gt;[Person]&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#333&quot;&gt;Banking ops agent performing case &amp;amp; approval actions in Salesforce&lt;/font&gt;" style="shape=mxgraph.basic.person2;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#003087;fontColor=#003087;fontSize=11;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
