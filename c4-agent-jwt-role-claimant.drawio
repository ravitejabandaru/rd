    </mxCell>
    <mxCell id="icb_bnd" value="ICB Authentication Platform" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f4ff;strokeColor=#003087;strokeDasharray=8 4;fontColor=#003087;fontSize=13;fontStyle=1;verticalAlign=top;arcSize=2;spacingTop=6;spacingLeft=10;align=left;" vertex="1" parent="1">
