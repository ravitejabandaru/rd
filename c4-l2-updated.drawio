    <mxCell id="ida" value="&lt;b&gt;IDAnywhere SAML IdP&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#555&quot;&gt;[External System | SAML 2.0]&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#444&quot;&gt;Provides SAML assertion for agent SSO.&lt;br&gt;⚠ Roles tied to Salesforce SEAL ID&lt;br&gt;— cannot be used in ForgeRock context.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#888888;fontColor=#333333;fontSize=11;verticalAlign=top;arcSize=4;spacingTop=5;" vertex="1" parent="1">
