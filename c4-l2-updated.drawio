    <mxCell id="fr" value="&lt;b&gt;ICB TMS ForgeRock&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#1e3a8a&quot;&gt;[Container | ForgeRock AM 7.x]&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#1e3a8a&quot;&gt;① Receives token exchange + internal JWT from Salesforce.&lt;br&gt;② Validates Salesforce JWT signature.&lt;br&gt;③ Extracts &lt;b&gt;chase.role&lt;/b&gt; claim.&lt;br&gt;④ Issues colleague token with &lt;b&gt;CRM_ROLE&lt;/b&gt; embedded.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#1d4ed8;fontColor=#1e3a8a;fontSize=11;verticalAlign=top;arcSize=4;spacingTop=5;" vertex="1" parent="1">
