  <diagram name="L3 — Component">&lt;mxGraphModel dx=&quot;1422&quot; dy=&quot;762&quot; grid=&quot;1&quot; gridSize=&quot;10&quot; guides=&quot;1&quot; tooltips=&quot;1&quot; connect=&quot;1&quot; arrows=&quot;1&quot; fold=&quot;1&quot; page=&quot;1&quot; pageScale=&quot;1&quot; pageWidth=&quot;1900&quot; pageHeight=&quot;1250&quot; math=&quot;0&quot; shadow=&quot;0&quot;&gt;&lt;root&gt;&lt;mxCell id=&quot;0&quot; /&gt;&lt;mxCell id=&quot;1&quot; parent=&quot;0&quot; /&gt;&lt;mxCell id=&quot;tb&quot; value=&quot;&quot; style=&quot;fillColor=#003087;strokeColor=none;&quot; vertex=&quot;1&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry x=&quot;0&quot; y=&quot;0&quot; width=&quot;1900&quot; height=&quot;78&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;tt&quot; value=&quot;C4 Component Diagram — ICB TMS ForgeRock &amp;amp; ICB Case Manager&quot; style=&quot;text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#ffffff;&quot; vertex=&quot;1&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry x=&quot;0&quot; y=&quot;8&quot; width=&quot;1900&quot; height=&quot;36&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;ts&quot; value=&quot;DECISION-4860  |  Level 3: Component  |  Internal components of the two modified containers  |  🟡 = New/Modified&quot; style=&quot;text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontColor=#b0c4de;&quot; vertex=&quot;1&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry x=&quot;0&quot; y=&quot;46&quot; width=&quot;1900&quot; height=&quot;26&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;sf_ext&quot; value=&quot;&amp;lt;b&amp;gt;Salesforce CRM&amp;lt;/b&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#555&amp;quot;&amp;gt;[External System]&amp;lt;/font&amp;gt;&amp;lt;br&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#444&amp;quot;&amp;gt;Sends token exchange request with self-signed internal JWT (chase.role). Receives colleague access token with CRM_ROLE claimant.&amp;lt;/font&amp;gt;&quot; style=&quot;rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontColor=#333333;fontSize=11;verticalAlign=top;arcSize=4;spacingTop=5;&quot; vertex=&quot;1&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry x=&quot;30&quot; y=&quot;330&quot; width=&quot;190&quot; height=&quot;160&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;ida_ext&quot; value=&quot;&amp;lt;b&amp;gt;IDAnywhere SAML IdP&amp;lt;/b&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#555&amp;quot;&amp;gt;[External System]&amp;lt;/font&amp;gt;&amp;lt;br&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#444&amp;quot;&amp;gt;Provides SAML assertion for agent identity. Metadata used by ForgeRock for assertion validation.&amp;lt;/font&amp;gt;&quot; style=&quot;rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontColor=#333333;fontSize=11;verticalAlign=top;arcSize=4;spacingTop=5;&quot; vertex=&quot;1&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry x=&quot;30&quot; y=&quot;100&quot; width=&quot;190&quot; height=&quot;150&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;florence_ext&quot; value=&quot;&amp;lt;b&amp;gt;Florence Case Manager&amp;lt;/b&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#555&amp;quot;&amp;gt;[External System]&amp;lt;/font&amp;gt;&amp;lt;br&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#444&amp;quot;&amp;gt;Receives Jpmorgan-Authorization-Attribute header from Case Manager. Enforces RBAC, no changes needed.&amp;lt;/font&amp;gt;&quot; style=&quot;rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontColor=#333333;fontSize=11;verticalAlign=top;arcSize=4;spacingTop=5;&quot; vertex=&quot;1&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry x=&quot;1670&quot; y=&quot;540&quot; width=&quot;195&quot; height=&quot;160&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;fr_bnd&quot; value=&quot;ICB TMS ForgeRock   [Container: ForgeRock AM 7.x]&quot; style=&quot;rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f4ff;strokeColor=#003087;strokeDasharray=8 4;fontColor=#003087;fontSize=13;fontStyle=1;verticalAlign=top;arcSize=2;spacingTop=6;spacingLeft=10;align=left;&quot; vertex=&quot;1&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry x=&quot;250&quot; y=&quot;85&quot; width=&quot;800&quot; height=&quot;500&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;fr_saml&quot; value=&quot;&amp;lt;b&amp;gt;SAML Assertion Handler&amp;lt;/b&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#0c4a6e&amp;quot;&amp;gt;[Auth Module]&amp;lt;/font&amp;gt;&amp;lt;br&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#1e3a5f&amp;quot;&amp;gt;Validates inbound SAML Bearer assertion from Salesforce. Maps agent subject to ForgeRock identity.&amp;lt;/font&amp;gt;&quot; style=&quot;rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0369a1;fontColor=#0c4a6e;fontSize=10;verticalAlign=top;arcSize=4;spacingTop=4;&quot; vertex=&quot;1&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry x=&quot;275&quot; y=&quot;145&quot; width=&quot;230&quot; height=&quot;130&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;fr_jwt&quot; value=&quot;&amp;lt;b&amp;gt;Internal JWT Inspector&amp;lt;/b&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#92400e&amp;quot;&amp;gt;🆕 NEW Component&amp;lt;/font&amp;gt;&amp;lt;br&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#78350f&amp;quot;&amp;gt;Validates signature on Salesforce self-signed JWT using Salesforce certificate. Extracts &amp;lt;b&amp;gt;chase.role&amp;lt;/b&amp;gt; claim value.&amp;lt;/font&amp;gt;&quot; style=&quot;rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontColor=#92400e;fontSize=10;verticalAlign=top;arcSize=4;spacingTop=4;&quot; vertex=&quot;1&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry x=&quot;275&quot; y=&quot;315&quot; width=&quot;230&quot; height=&quot;145&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;fr_map&quot; value=&quot;&amp;lt;b&amp;gt;Role Claimant Mapper&amp;lt;/b&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#92400e&amp;quot;&amp;gt;🆕 NEW Component&amp;lt;/font&amp;gt;&amp;lt;br&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#78350f&amp;quot;&amp;gt;Maps chase.role → CRM_ROLE. Validates role against approved allowlist. Rejects unknown roles (400). Passes claimant to Policy Engine.&amp;lt;/font&amp;gt;&quot; style=&quot;rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontColor=#92400e;fontSize=10;verticalAlign=top;arcSize=4;spacingTop=4;&quot; vertex=&quot;1&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry x=&quot;530&quot; y=&quot;315&quot; width=&quot;230&quot; height=&quot;145&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;fr_policy&quot; value=&quot;&amp;lt;b&amp;gt;OAuth2 Policy Engine&amp;lt;/b&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#0c4a6e&amp;quot;&amp;gt;[Authorisation Module]&amp;lt;/font&amp;gt;&amp;lt;br&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#1e3a5f&amp;quot;&amp;gt;Evaluates token issuance policies — scopes, grant types, client credentials. Decides whether to include role claimant based on grant context.&amp;lt;/font&amp;gt;&quot; style=&quot;rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0369a1;fontColor=#0c4a6e;fontSize=10;verticalAlign=top;arcSize=4;spacingTop=4;&quot; vertex=&quot;1&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry x=&quot;530&quot; y=&quot;145&quot; width=&quot;230&quot; height=&quot;130&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;fr_builder&quot; value=&quot;&amp;lt;b&amp;gt;Access Token Builder&amp;lt;/b&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#0c4a6e&amp;quot;&amp;gt;[Token Issuance Engine]&amp;lt;/font&amp;gt;&amp;lt;br&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#1e3a5f&amp;quot;&amp;gt;Constructs JWT colleague token. &amp;lt;b&amp;gt;Embeds CRM_ROLE&amp;lt;/b&amp;gt; as chase.crm_role claimant. Signs with ForgeRock RS256 private key.&amp;lt;/font&amp;gt;&quot; style=&quot;rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0369a1;fontColor=#0c4a6e;fontSize=10;verticalAlign=top;arcSize=4;spacingTop=4;&quot; vertex=&quot;1&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry x=&quot;785&quot; y=&quot;230&quot; width=&quot;220&quot; height=&quot;140&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;fr_keys&quot; value=&quot;&amp;lt;b&amp;gt;Key Store / JWKS Endpoint&amp;lt;/b&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#0c4a6e&amp;quot;&amp;gt;[Crypto Component]&amp;lt;/font&amp;gt;&amp;lt;br&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#1e3a5f&amp;quot;&amp;gt;Manages RS256 signing keys. Exposes GET /jwks for downstream consumers (Case Manager) to verify issued tokens.&amp;lt;/font&amp;gt;&quot; style=&quot;rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0369a1;fontColor=#0c4a6e;fontSize=10;verticalAlign=top;arcSize=4;spacingTop=4;&quot; vertex=&quot;1&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry x=&quot;785&quot; y=&quot;410&quot; width=&quot;220&quot; height=&quot;140&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;fe1&quot; value=&quot;SAML assertion&quot; style=&quot;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6b7280;strokeWidth=1.5;fontColor=#374151;fontSize=9;exitX=1;exitY=0.5;entryX=0;entryY=0.3;&quot; edge=&quot;1&quot; source=&quot;fr_saml&quot; target=&quot;fr_policy&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;fe2&quot; value=&quot;validated JWT string&quot; style=&quot;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6b7280;strokeWidth=1.5;fontColor=#374151;fontSize=9;exitX=1;exitY=0.5;entryX=0;entryY=0.5;&quot; edge=&quot;1&quot; source=&quot;fr_jwt&quot; target=&quot;fr_map&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;fe3&quot; value=&quot;validated chase.role value&quot; style=&quot;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6b7280;strokeWidth=1.5;fontColor=#374151;fontSize=9;exitX=1;exitY=0.3;entryX=0;entryY=0.7;&quot; edge=&quot;1&quot; source=&quot;fr_map&quot; target=&quot;fr_policy&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;fe4&quot; value=&quot;approved claims set incl. CRM_ROLE&quot; style=&quot;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6b7280;strokeWidth=1.5;fontColor=#374151;fontSize=9;exitX=1;exitY=0.5;entryX=0;entryY=0.35;&quot; edge=&quot;1&quot; source=&quot;fr_policy&quot; target=&quot;fr_builder&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;fe5&quot; value=&quot;sign token RS256&quot; style=&quot;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6b7280;strokeWidth=1.5;fontColor=#374151;fontSize=9;exitX=0.5;exitY=1;entryX=0.5;entryY=0;&quot; edge=&quot;1&quot; source=&quot;fr_builder&quot; target=&quot;fr_keys&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;fe6&quot; value=&quot;SAML assertion for validation&quot; style=&quot;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888;strokeWidth=1.5;fontColor=#555;fontSize=9;dashed=1;dashPattern=6 3;exitX=1;exitY=0.4;entryX=0;entryY=0.6;&quot; edge=&quot;1&quot; source=&quot;ida_ext&quot; target=&quot;fr_saml&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;fe7&quot; value=&quot;internal JWT (chase.role)&quot; style=&quot;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d97706;strokeWidth=2.5;fontColor=#92400e;fontSize=9;fontStyle=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;&quot; edge=&quot;1&quot; source=&quot;sf_ext&quot; target=&quot;fr_jwt&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;fe8&quot; value=&quot;Colleague token + CRM_ROLE  🆕&quot; style=&quot;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d97706;strokeWidth=2.5;fontColor=#92400e;fontSize=9;fontStyle=1;exitX=0;exitY=0.5;entryX=1;entryY=0.35;&quot; edge=&quot;1&quot; source=&quot;fr_builder&quot; target=&quot;sf_ext&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot;&gt;&lt;Array as=&quot;points&quot;&gt;&lt;mxPoint x=&quot;780&quot; y=&quot;300&quot; /&gt;&lt;mxPoint x=&quot;240&quot; y=&quot;440&quot; /&gt;&lt;/Array&gt;&lt;/mxGeometry&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;cm_bnd&quot; value=&quot;ICB Case Manager   [Container: Spring Boot REST API]&quot; style=&quot;rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f4ff;strokeColor=#003087;strokeDasharray=8 4;fontColor=#003087;fontSize=13;fontStyle=1;verticalAlign=top;arcSize=2;spacingTop=6;spacingLeft=10;align=left;&quot; vertex=&quot;1&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry x=&quot;250&quot; y=&quot;640&quot; width=&quot;1380&quot; height=&quot;550&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;cm_filter&quot; value=&quot;&amp;lt;b&amp;gt;API Gateway Filter&amp;lt;/b&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#0c4a6e&amp;quot;&amp;gt;[Security Filter]&amp;lt;/font&amp;gt;&amp;lt;br&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#1e3a5f&amp;quot;&amp;gt;Entry point for all inbound requests. Intercepts Authorization: Bearer token. Routes to JWT Validator.&amp;lt;/font&amp;gt;&quot; style=&quot;rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0369a1;fontColor=#0c4a6e;fontSize=10;verticalAlign=top;arcSize=4;spacingTop=4;&quot; vertex=&quot;1&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry x=&quot;275&quot; y=&quot;700&quot; width=&quot;220&quot; height=&quot;130&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;cm_val&quot; value=&quot;&amp;lt;b&amp;gt;JWT Validator&amp;lt;/b&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#0c4a6e&amp;quot;&amp;gt;[Security Component]&amp;lt;/font&amp;gt;&amp;lt;br&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#1e3a5f&amp;quot;&amp;gt;Fetches JWKS from ForgeRock. Verifies RS256 signature. Checks exp / nbf / iss. Rejects invalid tokens with 401.&amp;lt;/font&amp;gt;&quot; style=&quot;rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0369a1;fontColor=#0c4a6e;fontSize=10;verticalAlign=top;arcSize=4;spacingTop=4;&quot; vertex=&quot;1&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry x=&quot;525&quot; y=&quot;700&quot; width=&quot;220&quot; height=&quot;130&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;cm_role&quot; value=&quot;&amp;lt;b&amp;gt;Role Extractor&amp;lt;/b&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#92400e&amp;quot;&amp;gt;🆕 MODIFIED Component&amp;lt;/font&amp;gt;&amp;lt;br&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#78350f&amp;quot;&amp;gt;Reads &amp;lt;b&amp;gt;chase.crm_role&amp;lt;/b&amp;gt; claim from validated JWT payload. Backward-compatible — falls back gracefully if claim absent.&amp;lt;/font&amp;gt;&quot; style=&quot;rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontColor=#92400e;fontSize=10;verticalAlign=top;arcSize=4;spacingTop=4;&quot; vertex=&quot;1&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry x=&quot;775&quot; y=&quot;700&quot; width=&quot;230&quot; height=&quot;130&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;cm_service&quot; value=&quot;&amp;lt;b&amp;gt;Case Service&amp;lt;/b&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#0c4a6e&amp;quot;&amp;gt;[Business Service]&amp;lt;/font&amp;gt;&amp;lt;br&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#1e3a5f&amp;quot;&amp;gt;Core business logic for case and approval operations. Consults CRM_ROLE before delegating to Florence client.&amp;lt;/font&amp;gt;&quot; style=&quot;rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0369a1;fontColor=#0c4a6e;fontSize=10;verticalAlign=top;arcSize=4;spacingTop=4;&quot; vertex=&quot;1&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry x=&quot;1035&quot; y=&quot;700&quot; width=&quot;220&quot; height=&quot;130&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;cm_egress&quot; value=&quot;&amp;lt;b&amp;gt;Egress Auth/Authz Handler&amp;lt;/b&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#0c4a6e&amp;quot;&amp;gt;[Auth Component]&amp;lt;/font&amp;gt;&amp;lt;br&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#1e3a5f&amp;quot;&amp;gt;Handles outbound token exchange via Egress Authn/Authz. Prepares authenticated context for downstream call.&amp;lt;/font&amp;gt;&quot; style=&quot;rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0369a1;fontColor=#0c4a6e;fontSize=10;verticalAlign=top;arcSize=4;spacingTop=4;&quot; vertex=&quot;1&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry x=&quot;1035&quot; y=&quot;880&quot; width=&quot;220&quot; height=&quot;130&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;cm_cache&quot; value=&quot;&amp;lt;b&amp;gt;Token Cache Manager&amp;lt;/b&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#0c4a6e&amp;quot;&amp;gt;[Cache Component]&amp;lt;/font&amp;gt;&amp;lt;br&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#1e3a5f&amp;quot;&amp;gt;Caches validated tokens by hash. TTL aligned to token expiry. Avoids repeated JWKS calls.&amp;lt;/font&amp;gt;&quot; style=&quot;rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0369a1;fontColor=#0c4a6e;fontSize=10;verticalAlign=top;arcSize=4;spacingTop=4;&quot; vertex=&quot;1&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry x=&quot;525&quot; y=&quot;880&quot; width=&quot;220&quot; height=&quot;130&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;cm_fclient&quot; value=&quot;&amp;lt;b&amp;gt;Florence API Client&amp;lt;/b&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#92400e&amp;quot;&amp;gt;🆕 MODIFIED Component&amp;lt;/font&amp;gt;&amp;lt;br&amp;gt;&amp;lt;br&amp;gt;&amp;lt;font style=&amp;quot;font-size:9px;color:#78350f&amp;quot;&amp;gt;Builds outbound request. Injects &amp;lt;b&amp;gt;Jpmorgan-Authorization-Attribute: jpmc.crm.role=CRM_ROLE&amp;lt;/b&amp;gt; header. Delegates to Florence.&amp;lt;/font&amp;gt;&quot; style=&quot;rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontColor=#92400e;fontSize=10;verticalAlign=top;arcSize=4;spacingTop=4;&quot; vertex=&quot;1&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry x=&quot;1295&quot; y=&quot;700&quot; width=&quot;250&quot; height=&quot;130&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;ce1&quot; value=&quot;Bearer token&quot; style=&quot;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6b7280;strokeWidth=1.5;fontColor=#374151;fontSize=9;exitX=1;exitY=0.5;entryX=0;entryY=0.5;&quot; edge=&quot;1&quot; source=&quot;cm_filter&quot; target=&quot;cm_val&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;ce2&quot; value=&quot;validated JWT claims&quot; style=&quot;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6b7280;strokeWidth=1.5;fontColor=#374151;fontSize=9;exitX=1;exitY=0.5;entryX=0;entryY=0.5;&quot; edge=&quot;1&quot; source=&quot;cm_val&quot; target=&quot;cm_role&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;ce3&quot; value=&quot;enriched context + CRM_ROLE&quot; style=&quot;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6b7280;strokeWidth=1.5;fontColor=#374151;fontSize=9;exitX=1;exitY=0.5;entryX=0;entryY=0.5;&quot; edge=&quot;1&quot; source=&quot;cm_role&quot; target=&quot;cm_service&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;ce4&quot; value=&quot;prepare outbound call&quot; style=&quot;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6b7280;strokeWidth=1.5;fontColor=#374151;fontSize=9;exitX=0.5;exitY=1;entryX=0.5;entryY=0;&quot; edge=&quot;1&quot; source=&quot;cm_service&quot; target=&quot;cm_egress&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;ce5&quot; value=&quot;cache miss: store / hit: return&quot; style=&quot;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d6b656;strokeWidth=1.5;fontColor=#7a4800;fontSize=9;dashed=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;&quot; edge=&quot;1&quot; source=&quot;cm_val&quot; target=&quot;cm_cache&quot; parent=&quot;1&quot;&gt;&lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;ce6&quot; value=&quot;token + CRM_ROLE&quot; style=&quot;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6b7280;strokeWidth=1.5;fontColor=#374151;fontSize=9;exitX=1;exitY=0.5;entryX=0;entryY=0.7;&quot; edge=&quot;1&quot; source=&quot;cm_egress&quot; target=&quot;cm_fclient&quot; parent=&quot;1&quot;&gt;&lt;mxGeomet